!<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>Agora — Pensez librement</title>
<link rel="icon" type="image/svg+xml" href="data:image/svg+xml;base64,">
<meta name="theme-color" content="#f97316">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-title" content="Agora">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,500;0,700;1,500&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
:root {
  --cream: #fdf8f2;
  --cream2: #f5ede0;
  --warm: #ede0cc;
  --border: #e8d5bb;
  --orange: #f97316;
  --orange2: #ea6a0a;
  --amber: #d97706;
  --brown: #92400e;
  --text: #1c1208;
  --text2: #78583a;
  --text3: #b08060;
  --white: #ffffff;
  --shadow: 0 2px 16px rgba(180,100,30,0.10);
  --shadow2: 0 4px 32px rgba(180,100,30,0.16);
}

* { margin:0; padding:0; box-sizing:border-box; }
html, body { height:100%; overflow:hidden; }

body {
  background: var(--cream);
  color: var(--text);
  font-family: 'DM Sans', sans-serif;
  display: flex;
  flex-direction: column;
  height: 100vh;
}

/* ── API MODAL ── */
#api-modal {
  display: none;
  position: fixed; inset: 0;
  background: rgba(28,18,8,0.55);
  z-index: 9999;
  align-items: center;
  justify-content: center;
  backdrop-filter: blur(6px);
}
#api-modal.show { display: flex; }

.modal-card {
  background: var(--white);
  border-radius: 20px;
  padding: 2.5rem;
  max-width: 460px; width: 92%;
  box-shadow: var(--shadow2);
}

.modal-logo {
  width: 52px; height: 52px;
  background: var(--orange);
  border-radius: 14px;
  display: flex; align-items: center; justify-content: center;
  font-family: 'Playfair Display', serif;
  font-size: 1.6rem; color: white; font-weight: 700;
  margin-bottom: 1.2rem;
}

.modal-title {
  font-family: 'Playfair Display', serif;
  font-size: 1.4rem; font-weight: 700;
  color: var(--text); margin-bottom: 0.5rem;
}

.modal-sub {
  font-size: 0.85rem; color: var(--text2);
  line-height: 1.7; margin-bottom: 1.5rem;
}
.modal-sub a { color: var(--orange); text-decoration: none; font-weight: 500; }

.modal-input {
  width: 100%;
  border: 1.5px solid var(--border);
  border-radius: 10px;
  padding: 0.85rem 1rem;
  font-family: 'DM Sans', sans-serif;
  font-size: 0.9rem;
  color: var(--text);
  background: var(--cream);
  outline: none;
  transition: border 0.2s;
  margin-bottom: 0.5rem;
}
.modal-input:focus { border-color: var(--orange); }
.modal-error { display: none; color: #dc2626; font-size: 0.75rem; margin-bottom: 0.8rem; }

.modal-btns { display: flex; gap: 0.8rem; margin-top: 1.2rem; }

.btn-orange {
  background: var(--orange);
  color: white; border: none;
  border-radius: 10px;
  padding: 0.8rem 1.8rem;
  font-family: 'DM Sans', sans-serif;
  font-size: 0.9rem; font-weight: 600;
  cursor: pointer; transition: background 0.2s;
}
.btn-orange:hover { background: var(--orange2); }

.btn-ghost {
  background: transparent;
  border: 1.5px solid var(--border);
  border-radius: 10px;
  color: var(--text2);
  padding: 0.8rem 1.4rem;
  font-family: 'DM Sans', sans-serif;
  font-size: 0.9rem; cursor: pointer;
  transition: all 0.2s;
}
.btn-ghost:hover { border-color: var(--text2); }

/* ── SIDEBAR ── */
#sidebar {
  position: fixed; left: 0; top: 0; bottom: 0;
  width: 280px;
  background: var(--white);
  border-right: 1px solid var(--border);
  display: flex; flex-direction: column;
  transform: translateX(-100%);
  transition: transform 0.3s ease;
  z-index: 100;
  box-shadow: var(--shadow2);
}
#sidebar.open { transform: translateX(0); }

.sidebar-header {
  padding: 1.5rem 1.2rem 1rem;
  border-bottom: 1px solid var(--border);
  display: flex; align-items: center; gap: 0.8rem;
}

.logo-mark {
  width: 36px; height: 36px;
  background: linear-gradient(135deg, var(--orange), var(--amber));
  border-radius: 10px;
  display: flex; align-items: center; justify-content: center;
  font-family: 'Playfair Display', serif;
  font-size: 1.1rem; color: white; font-weight: 700;
  flex-shrink: 0;
}

.logo-text {
  font-family: 'Playfair Display', serif;
  font-size: 1.2rem; font-weight: 700;
  color: var(--text);
}
.logo-sub { font-size: 0.65rem; color: var(--text3); letter-spacing: 0.05em; }

.sidebar-section {
  padding: 1rem 1rem 0.5rem;
  font-size: 0.65rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--text3);
  font-weight: 600;
}

/* Agent cards */
.agent-card {
  margin: 0.3rem 0.8rem;
  padding: 0.9rem 1rem;
  border-radius: 12px;
  cursor: pointer;
  transition: all 0.18s;
  border: 1.5px solid transparent;
  display: flex; align-items: center; gap: 0.8rem;
}
.agent-card:hover { background: var(--cream2); }
.agent-card.active {
  background: linear-gradient(135deg, rgba(249,115,22,0.08), rgba(217,119,6,0.06));
  border-color: rgba(249,115,22,0.3);
}

.agent-avatar {
  width: 38px; height: 38px; border-radius: 10px;
  display: flex; align-items: center; justify-content: center;
  font-size: 1.1rem; flex-shrink: 0;
}
.agent-card.active .agent-avatar { box-shadow: 0 0 0 2px var(--orange); }

.agent-info { flex: 1; min-width: 0; }
.agent-name {
  font-size: 0.88rem; font-weight: 600;
  color: var(--text); margin-bottom: 0.15rem;
}
.agent-card.active .agent-name { color: var(--orange2); }
.agent-desc { font-size: 0.72rem; color: var(--text3); line-height: 1.3; }

/* History */
.hist-item {
  margin: 0.2rem 0.8rem;
  padding: 0.6rem 0.8rem;
  border-radius: 8px;
  cursor: pointer;
  transition: background 0.15s;
}
.hist-item:hover { background: var(--cream2); }
.hist-agent { font-size: 0.6rem; color: var(--orange); font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; }
.hist-q { font-size: 0.78rem; color: var(--text); line-height: 1.4; margin-top: 0.1rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.hist-time { font-size: 0.6rem; color: var(--text3); margin-top: 0.2rem; }
.hist-star { float: right; cursor: pointer; font-size: 0.85rem; }
.hist-star.on { color: var(--amber); }

.sidebar-scroll { flex: 1; overflow-y: auto; padding-bottom: 1rem; }
.sidebar-scroll::-webkit-scrollbar { width: 3px; }
.sidebar-scroll::-webkit-scrollbar-thumb { background: var(--border); border-radius: 2px; }

.sidebar-footer {
  padding: 1rem 1.2rem;
  border-top: 1px solid var(--border);
}

.api-pill {
  display: flex; align-items: center; gap: 0.6rem;
  padding: 0.6rem 0.8rem;
  border-radius: 8px;
  background: var(--cream);
  cursor: pointer;
  transition: background 0.15s;
  border: none; width: 100%;
  font-family: 'DM Sans', sans-serif;
}
.api-pill:hover { background: var(--cream2); }
.api-dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }
.api-dot.ok { background: #16a34a; box-shadow: 0 0 6px rgba(22,163,74,0.5); }
.api-dot.off { background: #dc2626; }
.api-label { font-size: 0.78rem; color: var(--text2); font-weight: 500; }

/* ── OVERLAY ── */
#overlay {
  display: none; position: fixed; inset: 0;
  background: rgba(0,0,0,0.3); z-index: 99;
}
#overlay.show { display: block; }

/* ── MAIN ── */
#main {
  flex: 1;
  display: flex;
  flex-direction: column;
  height: 100vh;
  overflow: hidden;
}

/* ── TOPBAR ── */
#topbar {
  background: var(--white);
  border-bottom: 1px solid var(--border);
  padding: 0 1rem;
  height: 58px;
  display: flex; align-items: center; gap: 1rem;
  flex-shrink: 0;
  box-shadow: 0 1px 8px rgba(180,100,30,0.06);
}

.menu-btn {
  background: none; border: none;
  cursor: pointer; padding: 0.4rem;
  border-radius: 8px; color: var(--text2);
  font-size: 1.2rem; display: flex;
  align-items: center;
  transition: background 0.15s;
}
.menu-btn:hover { background: var(--cream2); }

.topbar-agent {
  display: flex; align-items: center; gap: 0.6rem;
  flex: 1;
}
.topbar-avatar {
  width: 30px; height: 30px; border-radius: 8px;
  display: flex; align-items: center; justify-content: center;
  font-size: 0.9rem;
}
.topbar-name {
  font-family: 'Playfair Display', serif;
  font-size: 1rem; font-weight: 700; color: var(--text);
}
.topbar-role { font-size: 0.68rem; color: var(--text3); }

.new-chat-btn {
  background: var(--orange);
  color: white; border: none;
  border-radius: 8px;
  padding: 0.45rem 1rem;
  font-family: 'DM Sans', sans-serif;
  font-size: 0.78rem; font-weight: 600;
  cursor: pointer; transition: background 0.2s;
  white-space: nowrap;
}
.new-chat-btn:hover { background: var(--orange2); }

/* ── MESSAGES ── */
#messages {
  flex: 1;
  overflow-y: auto;
  padding: 1.5rem 1rem;
  display: flex;
  flex-direction: column;
  gap: 1rem;
}
#messages::-webkit-scrollbar { width: 4px; }
#messages::-webkit-scrollbar-thumb { background: var(--border); border-radius: 2px; }

/* Welcome */
#welcome {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 2rem 1rem;
  text-align: center;
  gap: 1.2rem;
  min-height: 300px;
}

.welcome-icon {
  width: 72px; height: 72px;
  background: linear-gradient(135deg, var(--orange), var(--amber));
  border-radius: 20px;
  display: flex; align-items: center; justify-content: center;
  font-family: 'Playfair Display', serif;
  font-size: 2.2rem; color: white; font-weight: 700;
  box-shadow: 0 8px 24px rgba(249,115,22,0.35);
}

.welcome-title {
  font-family: 'Playfair Display', serif;
  font-size: 1.6rem; font-weight: 700;
  color: var(--text);
  line-height: 1.2;
}

.welcome-sub {
  font-size: 0.88rem; color: var(--text2);
  line-height: 1.7; max-width: 340px;
}

.suggestions {
  display: flex; flex-direction: column; gap: 0.5rem;
  width: 100%; max-width: 380px;
  margin-top: 0.5rem;
}

.sugg-btn {
  background: var(--white);
  border: 1.5px solid var(--border);
  border-radius: 12px;
  padding: 0.75rem 1rem;
  font-family: 'DM Sans', sans-serif;
  font-size: 0.8rem; color: var(--text2);
  cursor: pointer; text-align: left;
  transition: all 0.18s; line-height: 1.4;
}
.sugg-btn:hover {
  border-color: var(--orange);
  color: var(--orange2);
  background: rgba(249,115,22,0.04);
}

/* Messages */
.msg { display: flex; flex-direction: column; gap: 0.3rem; animation: fadeUp 0.25s ease; }
@keyframes fadeUp { from{opacity:0;transform:translateY(8px)} to{opacity:1;transform:translateY(0)} }

.msg.user { align-items: flex-end; }
.msg.ai { align-items: flex-start; }

.msg-meta {
  font-size: 0.65rem; color: var(--text3);
  display: flex; align-items: center; gap: 0.4rem;
  padding: 0 0.3rem;
}
.msg-meta .avatar {
  width: 18px; height: 18px; border-radius: 5px;
  display: flex; align-items: center; justify-content: center;
  font-size: 0.6rem;
}

.msg-bubble {
  max-width: 88%;
  padding: 0.9rem 1.1rem;
  border-radius: 16px;
  font-size: 0.88rem;
  line-height: 1.75;
}

.msg.user .msg-bubble {
  background: linear-gradient(135deg, var(--orange), var(--amber));
  color: white;
  border-radius: 16px 16px 4px 16px;
}

.msg.ai .msg-bubble {
  background: var(--white);
  color: var(--text);
  border: 1.5px solid var(--border);
  border-radius: 4px 16px 16px 16px;
  box-shadow: var(--shadow);
}

.msg-actions {
  display: flex; gap: 0.5rem; padding: 0 0.3rem;
}
.msg-action {
  font-size: 0.65rem; color: var(--text3);
  cursor: pointer; padding: 0.2rem 0.4rem;
  border-radius: 4px; transition: all 0.15s;
  background: none; border: none;
  font-family: 'DM Sans', sans-serif;
}
.msg-action:hover { color: var(--orange); background: rgba(249,115,22,0.08); }
.msg-action.starred { color: var(--amber); }

/* Doc badge */
#doc-badge {
  display: none;
  margin: 0 1rem;
  padding: 0.6rem 1rem;
  background: rgba(249,115,22,0.08);
  border: 1.5px solid rgba(249,115,22,0.25);
  border-radius: 10px;
  font-size: 0.78rem; color: var(--orange2);
  align-items: center; gap: 0.6rem;
  flex-shrink: 0;
}
#doc-badge.show { display: flex; }
.doc-badge-name { flex: 1; font-weight: 500; }
.doc-badge-close { background: none; border: none; cursor: pointer; color: var(--text3); font-size: 0.9rem; }

/* Loading */
#loading {
  display: none;
  align-items: flex-start;
  gap: 0.6rem;
  padding: 0 0.3rem;
}
#loading.show { display: flex; }
.loading-bubble {
  background: var(--white);
  border: 1.5px solid var(--border);
  border-radius: 4px 16px 16px 16px;
  padding: 0.9rem 1.2rem;
  display: flex; gap: 5px; align-items: center;
  box-shadow: var(--shadow);
}
.dot { width: 7px; height: 7px; border-radius: 50%; background: var(--orange); opacity: 0.4; animation: dotPulse 1.2s ease-in-out infinite; }
.dot:nth-child(2) { animation-delay: 0.2s; }
.dot:nth-child(3) { animation-delay: 0.4s; }
@keyframes dotPulse { 0%,60%,100%{opacity:0.2;transform:scale(0.8)} 30%{opacity:1;transform:scale(1)} }

/* ── INPUT AREA ── */
#input-wrap {
  background: var(--white);
  border-top: 1px solid var(--border);
  padding: 0.8rem 1rem;
  flex-shrink: 0;
}

.input-box {
  background: var(--cream);
  border: 1.5px solid var(--border);
  border-radius: 14px;
  display: flex;
  align-items: flex-end;
  gap: 0.5rem;
  padding: 0.6rem 0.8rem;
  transition: border 0.2s;
}
.input-box:focus-within { border-color: var(--orange); background: var(--white); }

#msg-input {
  flex: 1; background: transparent; border: none; outline: none;
  font-family: 'DM Sans', sans-serif;
  font-size: 0.9rem; color: var(--text);
  resize: none; min-height: 24px; max-height: 120px;
  line-height: 1.5; padding: 0.2rem 0;
}
#msg-input::placeholder { color: var(--text3); }

.input-actions { display: flex; align-items: center; gap: 0.3rem; }

.upload-btn {
  background: none; border: none;
  cursor: pointer; padding: 0.3rem;
  border-radius: 6px; color: var(--text3);
  font-size: 1rem; transition: all 0.15s;
  line-height: 1;
}
.upload-btn:hover { color: var(--orange); background: rgba(249,115,22,0.08); }

.send-btn {
  width: 34px; height: 34px;
  background: var(--orange);
  border: none; border-radius: 8px;
  color: white; cursor: pointer;
  display: flex; align-items: center; justify-content: center;
  font-size: 0.9rem;
  transition: all 0.2s; flex-shrink: 0;
}
.send-btn:hover { background: var(--orange2); }
.send-btn:disabled { background: var(--border); cursor: not-allowed; }

.input-hint {
  font-size: 0.65rem; color: var(--text3);
  text-align: center; margin-top: 0.5rem;
}

#file-input { display: none; }

/* Tabs in sidebar */
.stabs {
  display: flex;
  border-bottom: 1px solid var(--border);
  margin-top: 0.5rem;
}
.stab {
  flex: 1; padding: 0.6rem 0;
  font-size: 0.7rem; font-weight: 600;
  text-align: center; cursor: pointer;
  color: var(--text3); border-bottom: 2px solid transparent;
  transition: all 0.15s; background: none; border-top: none; border-left: none; border-right: none;
  font-family: 'DM Sans', sans-serif; letter-spacing: 0.05em;
}
.stab.active { color: var(--orange); border-bottom-color: var(--orange); }

.stab-content { display: none; }
.stab-content.active { display: block; }

.empty-msg {
  padding: 2rem 1rem; text-align: center;
  font-size: 0.78rem; color: var(--text3); line-height: 1.7;
}

@media (min-width: 700px) {
  #sidebar { transform: translateX(0); position: relative; flex-shrink: 0; box-shadow: none; }
  #overlay { display: none !important; }
  #main { margin-left: 0; }
  body { flex-direction: row; }
  .menu-btn { display: none; }
}
</style>
</head>
<body>

<!-- API Modal -->
<div id="api-modal">
  <div class="modal-card">
    <div class="modal-logo">A</div>
    <div class="modal-title">Bienvenue sur Agora</div>
    <p class="modal-sub">
      Pour activer l'intelligence de vos conseillers, entrez votre clé API Anthropic.<br><br>
      → Obtenez-la gratuitement sur <a href="https://console.anthropic.com" target="_blank">console.anthropic.com</a> → <strong>API Keys</strong><br>
      → Elle est stockée sur votre appareil uniquement. Jamais partagée.
    </p>
    <input id="api-key-input" class="modal-input" type="password" placeholder="sk-ant-...">
    <div id="api-error" class="modal-error">⚠ Format invalide — la clé doit commencer par "sk-"</div>
    <div class="modal-btns">
      <button class="btn-orange" onclick="confirmKey()">Activer Agora</button>
      <button class="btn-ghost" onclick="closeModal()">Plus tard</button>
    </div>
  </div>
</div>

<!-- Overlay mobile -->
<div id="overlay" onclick="closeSidebar()"></div>

<!-- Sidebar -->
<div id="sidebar">
  <div class="sidebar-header">
    <div class="logo-mark" style="padding:4px;"><img src="data:image/svg+xml;base64," style="width:100%;height:100%;object-fit:contain;"></div>
    <div>
      <div class="logo-text">Agora</div>
      <div class="logo-sub">Pensez librement</div>
    </div>
  </div>

  <div class="stabs">
    <button class="stab active" onclick="switchStab('agents')">Conseillers</button>
    <button class="stab" onclick="switchStab('history')">Historique</button>
    <button class="stab" onclick="switchStab('favs')">★ Favoris</button>
  </div>

  <div class="sidebar-scroll">

    <!-- Agents tab -->
    <div class="stab-content active" id="stab-agents">
      <div class="sidebar-section">Choisissez votre conseiller</div>

      <div class="agent-card active" id="ag-socrate" onclick="selectAgent('socrate')">
        <div class="agent-avatar" style="background:#fff3e0;">🗿</div>
        <div class="agent-info">
          <div class="agent-name">Socrate</div>
          <div class="agent-desc">Déconstruit vos certitudes par le questionnement</div>
        </div>
      </div>

      <div class="agent-card" id="ag-diogene" onclick="selectAgent('diogene')">
        <div class="agent-avatar" style="background:#fce7f3;">🪔</div>
        <div class="agent-info">
          <div class="agent-name">Diogène</div>
          <div class="agent-desc">Renverse les conventions, dit la vérité qui dérange</div>
        </div>
      </div>

      <div class="agent-card" id="ag-voltaire" onclick="selectAgent('voltaire')">
        <div class="agent-avatar" style="background:#e0f2fe;">🔎</div>
        <div class="agent-info">
          <div class="agent-name">Voltaire</div>
          <div class="agent-desc">Analyse, enquête, démonte les arguments avec ironie</div>
        </div>
      </div>
    </div>

    <!-- History tab -->
    <div class="stab-content" id="stab-history">
      <div id="hist-list">
        <div class="empty-msg" id="hist-empty">Aucune conversation pour l'instant.<br>Posez votre première question !</div>
      </div>
    </div>

    <!-- Favs tab -->
    <div class="stab-content" id="stab-favs">
      <div id="fav-list">
        <div class="empty-msg" id="fav-empty">Aucun favori.<br>Cliquez ★ sur une réponse pour la sauvegarder.</div>
      </div>
    </div>

  </div>

  <div class="sidebar-footer">
    <button class="api-pill" onclick="openModal()">
      <div class="api-dot off" id="api-dot"></div>
      <span class="api-label" id="api-label">Configurer la clé API</span>
    </button>
  </div>
</div>

<!-- Main -->
<div id="main">

  <!-- Topbar -->
  <div id="topbar">
    <button class="menu-btn" onclick="toggleSidebar()">☰</button>
    <div class="topbar-agent">
      <div class="topbar-avatar" id="tb-avatar" style="background:#fff3e0;">🗿</div>
      <div>
        <div class="topbar-name" id="tb-name">Socrate</div>
        <div class="topbar-role" id="tb-role">Maïeutique & questionnement</div>
      </div>
    </div>
    <button class="new-chat-btn" onclick="newChat()">+ Nouvelle discussion</button>
  </div>

  <!-- Doc badge -->
  <div id="doc-badge">
    <span>📄</span>
    <span class="doc-badge-name" id="doc-name">—</span>
    <button class="doc-badge-close" onclick="clearDoc()">✕</button>
  </div>

  <!-- Messages -->
  <div id="messages">
    <div id="welcome">
      <div class="welcome-icon" style="padding:10px;"><img src="data:image/svg+xml;base64," style="width:100%;height:100%;object-fit:contain;"></div>
      <div class="welcome-title">Bienvenue sur Agora</div>
      <div class="welcome-sub">Un espace de pensée libre où trois esprits d'exception vous accompagnent. Aucune question n'est interdite.</div>
      <div class="suggestions" id="suggestions"></div>
    </div>
    <div id="loading">
      <div class="loading-bubble">
        <div class="dot"></div>
        <div class="dot"></div>
        <div class="dot"></div>
      </div>
    </div>
  </div>

  <!-- Input -->
  <div id="input-wrap">
    <div class="input-box">
      <textarea id="msg-input" rows="1" placeholder="Posez votre question à votre conseiller..."></textarea>
      <div class="input-actions">
        <button class="upload-btn" onclick="document.getElementById('file-input').click()" title="Joindre un document">📎</button>
        <button class="send-btn" id="send-btn" onclick="sendMessage()">➤</button>
      </div>
    </div>
    <input type="file" id="file-input" accept=".txt,.md,.pdf" onchange="loadFile(event)">
    <div class="input-hint">Entrée pour envoyer · Maj+Entrée pour un saut de ligne</div>
  </div>

</div>

<script>
// ── State ──────────────────────────────────────────
let currentAgent = 'socrate';
let conversation = [];
let docContent = null, docName = null;
let history = JSON.parse(localStorage.getItem('agora_history') || '[]');
let favorites = JSON.parse(localStorage.getItem('agora_favorites') || '[]');

// ── Agents ─────────────────────────────────────────
const agents = {
  socrate: {
    name: 'Socrate',
    role: 'Maïeutique & questionnement',
    avatar: '🗿',
    avatarBg: '#fff3e0',
    suggestions: [
      'La liberté peut-elle exister sans responsabilité ?',
      'Qu\'est-ce que vraiment "réussir sa vie" ?',
      'Peut-on être heureux dans une société injuste ?',
      'L\'intelligence artificielle peut-elle penser ?'
    ],
    system: `Tu es Socrate, le philosophe grec. Tu aides les gens à penser par eux-mêmes grâce à la maïeutique.

STYLE : Bienveillant mais incisif. Tu poses des questions qui font réfléchir, tu déconstruis les évidences sans agressivité. Tu es un guide, pas un juge.

RÈGLES :
- Tu explores tous les sujets sans tabou, avec sagesse
- Tu conclus chaque réponse par une question ouverte qui invite à aller plus loin
- Tu utilises des exemples concrets et accessibles
- Réponses en français, 250-350 mots, ton philosophique mais accessible
- Si un document est fourni, tu l'analyses avec le même esprit critique
- Tu ne prends jamais de position définitive — tu accompagnes la réflexion`
  },
  diogene: {
    name: 'Diogène',
    role: 'Vérité brute & liberté de pensée',
    avatar: '🪔',
    avatarBg: '#fce7f3',
    suggestions: [
      'La politesse est-elle une forme de mensonge ?',
      'Les réseaux sociaux nous rendent-ils plus libres ou plus esclaves ?',
      'Pourquoi obéit-on à des lois qu\'on n\'a pas choisies ?',
      'Le confort est-il l\'ennemi de la pensée ?'
    ],
    system: `Tu es Diogène de Sinope, le philosophe cynique qui vivait dans un tonneau et disait tout haut ce que les autres pensent tout bas.

STYLE : Direct, sans détour, parfois provocateur mais jamais cruel. Tu aimes renverser les conventions et montrer l'absurdité des comportements humains.

RÈGLES :
- Tu dis la vérité même quand elle est inconfortable
- Tu questionnes les normes sociales, politiques, morales avec audace
- Tu utilises l'humour et l'ironie pour faire passer des vérités profondes
- Réponses en français, 250-350 mots, ton franc et vivant
- Si un document est fourni, tu le passes au crible sans complaisance
- Tu n'as pas de vache sacrée mais tu restes constructif`
  },
  voltaire: {
    name: 'Voltaire',
    role: 'Analyse critique & enquête',
    avatar: '🔎',
    avatarBg: '#e0f2fe',
    suggestions: [
      'Les médias sont-ils vraiment indépendants ?',
      'Peut-on faire confiance aux experts ?',
      'La démocratie produit-elle les meilleurs dirigeants ?',
      'Le progrès technique améliore-t-il vraiment nos vies ?'
    ],
    system: `Tu es Voltaire, l'écrivain et philosophe des Lumières, champion de la raison, de la tolérance et de la liberté d'expression.

STYLE : Brillant, ironique, rigoureux. Tu examines les faits, démontres les contradictions, démythifie les discours avec élégance.

RÈGLES :
- Tu analyses toutes les positions avec rigueur et sans parti pris
- Tu identifies les intérêts cachés, les contradictions, les arguments fallacieux
- Tu distingues faits et opinions avec clarté
- Réponses en français, 250-350 mots, style vif et précis
- Si un document est fourni, tu fais un audit critique et argumenté
- Tu peux être mordant mais toujours dans l'intérêt de la vérité`
  }
};

// ── API Key ─────────────────────────────────────────
function getKey() { return localStorage.getItem('agora_key') || ''; }
function openModal() { document.getElementById('api-modal').classList.add('show'); document.getElementById('api-key-input').value = getKey(); }
function closeModal() { document.getElementById('api-modal').classList.remove('show'); }
function confirmKey() {
  const v = document.getElementById('api-key-input').value.trim();
  if (!v.startsWith('sk-')) { document.getElementById('api-error').style.display = 'block'; return; }
  localStorage.setItem('agora_key', v);
  document.getElementById('api-error').style.display = 'none';
  closeModal(); updateStatus();
}
function updateStatus() {
  const k = getKey();
  const dot = document.getElementById('api-dot');
  const label = document.getElementById('api-label');
  if (k) { dot.className = 'api-dot ok'; label.textContent = 'Clé API active'; }
  else { dot.className = 'api-dot off'; label.textContent = 'Configurer la clé API'; }
}

// ── Sidebar ─────────────────────────────────────────
function toggleSidebar() {
  document.getElementById('sidebar').classList.toggle('open');
  document.getElementById('overlay').classList.toggle('show');
}
function closeSidebar() {
  document.getElementById('sidebar').classList.remove('open');
  document.getElementById('overlay').classList.remove('show');
}

// ── Tabs ─────────────────────────────────────────────
function switchStab(t) {
  document.querySelectorAll('.stab').forEach((b,i) => b.classList.toggle('active', ['agents','history','favs'][i] === t));
  document.querySelectorAll('.stab-content').forEach((c,i) => c.classList.toggle('active', ['stab-agents','stab-history','stab-favs'][i] === 'stab-'+t));
}

// ── Agent ─────────────────────────────────────────────
function selectAgent(a) {
  currentAgent = a;
  document.querySelectorAll('.agent-card').forEach(c => c.classList.remove('active'));
  document.getElementById('ag-'+a).classList.add('active');
  const ag = agents[a];
  document.getElementById('tb-avatar').textContent = ag.avatar;
  document.getElementById('tb-avatar').style.background = ag.avatarBg;
  document.getElementById('tb-name').textContent = ag.name;
  document.getElementById('tb-role').textContent = ag.role;
  loadSuggestions(a);
  closeSidebar();
}

function loadSuggestions(a) {
  const el = document.getElementById('suggestions');
  el.innerHTML = '';
  agents[a].suggestions.forEach(s => {
    const b = document.createElement('button');
    b.className = 'sugg-btn';
    b.textContent = s;
    b.onclick = () => { document.getElementById('msg-input').value = s; sendMessage(); };
    el.appendChild(b);
  });
}

// ── Document ──────────────────────────────────────────
function loadFile(e) {
  const file = e.target.files[0]; if (!file) return;
  docName = file.name;
  const reader = new FileReader();
  reader.onload = ev => {
    docContent = ev.target.result;
    document.getElementById('doc-badge').classList.add('show');
    document.getElementById('doc-name').textContent = docName;
  };
  reader.readAsText(file);
  e.target.value = '';
}
function clearDoc() {
  docContent = null; docName = null;
  document.getElementById('doc-badge').classList.remove('show');
}

// ── Chat ──────────────────────────────────────────────
function newChat() {
  conversation = [];
  const msgs = document.getElementById('messages');
  msgs.innerHTML = '';
  const welcome = document.createElement('div');
  welcome.id = 'welcome';
  welcome.innerHTML = `
    <div class="welcome-icon" style="padding:10px;"><img src="data:image/svg+xml;base64," style="width:100%;height:100%;object-fit:contain;"></div>
    <div class="welcome-title">Nouvelle discussion</div>
    <div class="welcome-sub">Quelle question souhaitez-vous explorer avec ${agents[currentAgent].name} ?</div>
    <div class="suggestions" id="suggestions"></div>`;
  const loading = document.createElement('div');
  loading.id = 'loading';
  loading.innerHTML = '<div class="loading-bubble"><div class="dot"></div><div class="dot"></div><div class="dot"></div></div>';
  msgs.appendChild(welcome);
  msgs.appendChild(loading);
  loadSuggestions(currentAgent);
  closeSidebar();
}

function addMsg(role, text, historyIndex) {
  const welcome = document.getElementById('welcome');
  if (welcome) welcome.remove();
  const loading = document.getElementById('loading');
  const ag = agents[currentAgent];

  const wrap = document.createElement('div');
  wrap.className = 'msg ' + role;

  const meta = document.createElement('div');
  meta.className = 'msg-meta';
  if (role === 'ai') {
    meta.innerHTML = `<div class="avatar" style="background:${ag.avatarBg}">${ag.avatar}</div><span>${ag.name}</span>`;
  } else {
    meta.innerHTML = `<span>Vous</span>`;
  }

  const bubble = document.createElement('div');
  bubble.className = 'msg-bubble';
  bubble.innerHTML = text.replace(/\n/g, '<br>');

  wrap.appendChild(meta);
  wrap.appendChild(bubble);

  if (role === 'ai') {
    const actions = document.createElement('div');
    actions.className = 'msg-actions';
    const star = document.createElement('button');
    star.className = 'msg-action';
    const isFav = historyIndex !== undefined && favorites.some(f => f.idx === historyIndex);
    star.textContent = isFav ? '★ Sauvegardé' : '☆ Sauvegarder';
    if (isFav) star.classList.add('starred');
    star.onclick = () => toggleFav(historyIndex, star);
    actions.appendChild(star);
    wrap.appendChild(actions);
  }

  const msgs = document.getElementById('messages');
  msgs.insertBefore(wrap, loading);
  msgs.scrollTop = msgs.scrollHeight;
}

// ── Send ──────────────────────────────────────────────
async function sendMessage() {
  const input = document.getElementById('msg-input');
  const q = input.value.trim(); if (!q) return;
  const key = getKey(); if (!key) { openModal(); return; }

  input.value = ''; input.style.height = 'auto';
  document.getElementById('send-btn').disabled = true;

  let userContent = q;
  if (docContent) userContent = `[Document joint : ${docName}]\n${docContent.substring(0,5000)}\n\n[Question] : ${q}`;

  conversation.push({ role: 'user', content: userContent });
  addMsg('user', q);

  const loading = document.getElementById('loading');
  loading.classList.add('show');
  document.getElementById('messages').scrollTop = document.getElementById('messages').scrollHeight;

  const ag = agents[currentAgent];

  try {
    const res = await fetch('https://api.anthropic.com/v1/messages', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'x-api-key': key,
        'anthropic-version': '2023-06-01',
        'anthropic-dangerous-direct-browser-access': 'true'
      },
      body: JSON.stringify({
        model: 'claude-sonnet-4-20250514',
        max_tokens: 1000,
        system: ag.system,
        messages: conversation
      })
    });

    const data = await res.json();
    const reply = data.content?.map(b => b.text || '').join('') || 'Une erreur est survenue.';
    conversation.push({ role: 'assistant', content: reply });

    const entry = {
      agent: currentAgent,
      agentName: ag.name,
      question: q,
      answer: reply,
      time: new Date().toLocaleTimeString('fr-FR', { hour: '2-digit', minute: '2-digit' }),
      date: new Date().toLocaleDateString('fr-FR')
    };
    history.unshift(entry);
    if (history.length > 50) history.pop();
    localStorage.setItem('agora_history', JSON.stringify(history));

    loading.classList.remove('show');
    addMsg('ai', reply, 0);
    renderHistory();

  } catch(err) {
    loading.classList.remove('show');
    addMsg('ai', '⚠️ Erreur de connexion. Vérifiez votre clé API et réessayez.');
  }

  document.getElementById('send-btn').disabled = false;
}

// ── History ───────────────────────────────────────────
function renderHistory() {
  const c = document.getElementById('hist-list');
  if (!history.length) { c.innerHTML = '<div class="empty-msg">Aucune conversation pour l\'instant.</div>'; return; }
  c.innerHTML = '';
  history.forEach((h, i) => {
    const d = document.createElement('div');
    d.className = 'hist-item';
    const isFav = favorites.some(f => f.question === h.question && f.date === h.date);
    d.innerHTML = `
      <div class="hist-agent">${h.agentName} <span class="hist-star ${isFav?'on':''}" onclick="toggleFavHist(${i},this)">★</span></div>
      <div class="hist-q">${h.question}</div>
      <div class="hist-time">${h.date} · ${h.time}</div>`;
    d.querySelector('.hist-q').onclick = () => {
      document.getElementById('msg-input').value = h.question;
      selectAgent(h.agent);
      closeSidebar();
    };
    c.appendChild(d);
  });
}

// ── Favorites ─────────────────────────────────────────
function toggleFav(idx, btn) {
  const entry = history[idx]; if (!entry) return;
  const fi = favorites.findIndex(f => f.question === entry.question && f.date === entry.date);
  if (fi >= 0) { favorites.splice(fi, 1); btn.textContent = '☆ Sauvegarder'; btn.classList.remove('starred'); }
  else { favorites.unshift({...entry}); btn.textContent = '★ Sauvegardé'; btn.classList.add('starred'); }
  localStorage.setItem('agora_favorites', JSON.stringify(favorites));
  renderFavs();
}

function toggleFavHist(i, el) {
  const h = history[i];
  const fi = favorites.findIndex(f => f.question === h.question && f.date === h.date);
  if (fi >= 0) { favorites.splice(fi, 1); el.classList.remove('on'); }
  else { favorites.unshift({...h}); el.classList.add('on'); }
  localStorage.setItem('agora_favorites', JSON.stringify(favorites));
  renderFavs();
}

function renderFavs() {
  const c = document.getElementById('fav-list');
  if (!favorites.length) { c.innerHTML = '<div class="empty-msg">Aucun favori.<br>Cliquez ★ sur une réponse.</div>'; return; }
  c.innerHTML = '';
  favorites.forEach(f => {
    const d = document.createElement('div');
    d.className = 'hist-item';
    d.innerHTML = `<div class="hist-agent">★ ${f.agentName}</div><div class="hist-q">${f.question}</div><div class="hist-time">${f.date}</div>`;
    d.onclick = () => { document.getElementById('msg-input').value = f.question; selectAgent(f.agent); closeSidebar(); };
    c.appendChild(d);
  });
}

// ── Textarea auto-resize ──────────────────────────────
document.getElementById('msg-input').addEventListener('input', function() {
  this.style.height = 'auto';
  this.style.height = Math.min(this.scrollHeight, 120) + 'px';
});
document.getElementById('msg-input').addEventListener('keydown', e => {
  if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendMessage(); }
});

// ── Init ──────────────────────────────────────────────
updateStatus();
loadSuggestions('socrate');
renderHistory();
renderFavs();
if (!getKey()) openModal();
</script>
</body>
</html>
